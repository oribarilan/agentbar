{
  "name": "@agentbar/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && cargo check --manifest-path src-tauri/Cargo.toml",
    "build:web": "vite build",
    "build:tauri": "cargo check --manifest-path src-tauri/Cargo.toml",
    "lint": "tsc --noEmit",
    "format": "prettier --check \"src/**/*.{ts,tsx,css}\" \"README.md\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,css}\" \"README.md\"",
    "test": "vitest run --passWithNoTests && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "prettier": "^3.3.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vitest": "^1.6.0"
  }
}
