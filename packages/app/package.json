{
  "name": "@agentbar/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && cargo check --manifest-path src-tauri/Cargo.toml",
    "build:web": "vite build",
    "build:tauri": "cargo check --manifest-path src-tauri/Cargo.toml",
    "lint": "tsc --noEmit",
    "format": "prettier --plugin prettier-plugin-svelte --check \"src/**/*.{ts,svelte,css}\" \"tests/**/*.ts\" \"tests-ui/**/*.ts\" \"README.md\"",
    "format:fix": "prettier --plugin prettier-plugin-svelte --write \"src/**/*.{ts,svelte,css}\" \"tests/**/*.ts\" \"tests-ui/**/*.ts\" \"README.md\"",
    "test": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml && playwright test",
    "test:watch": "vitest",
    "test:ui": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "@agentbar/plugin": "workspace:*",
    "svelte": "^4.2.18"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@playwright/test": "^1.44.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.1",
    "@tsconfig/svelte": "^5.0.4",
    "prettier": "^3.3.2",
    "prettier-plugin-svelte": "^3.2.4",
    "svelte-check": "^3.8.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.13",
    "vitest": "^1.6.0"
  }
}
